; Draws a Volume with a perlin noise (similar to smoke) inside a cube

fEnableDepthBufferClearing 0
fDisableDepthTest 0
fDisableDepthMask 1
fEnableDrawWireframe 0
fFilter 0

[shader]
path /resources/shaders/sections/drawVolume/drawVolume-perlin.glsl
uniform vec3 uScale v1:=1;v2:=1;v3:=1;
uniform vec3 uCameraPos v1:=cam_posX;v2:=cam_posY;v3:=cam_posZ;
uniform vec3 u_colorTint v1:=1;v2:=1;v3:=1;
uniform float time v1:=t;

[expression:run]
tx:=0; ty:=0; tz:=0;
rx:=0; ry:=0; rz:=0;
sx:=1; sy:=1; sz:=1;
